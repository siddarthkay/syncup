# Copy this file to .env.fastlane and fill in. The Makefile auto-loads it for
# ios-certs-init / ios-certs / ios-pr / ios-release. CI uses GitHub secrets
# instead; this file is local-only and .gitignored.

# App Store Connect API key (Users and Access → Integrations → App Store Connect API).
# The key Role must be "Admin" for match to create certificates + profiles.
APP_STORE_CONNECT_KEY_ID=
APP_STORE_CONNECT_ISSUER_ID=
# Easiest locally: point at the .p8 file you downloaded (don't move it into the repo).
APP_STORE_CONNECT_KEY_P8_PATH=~/Downloads/AuthKey_XXXXXXXXXX.p8
# Alternative (CI uses this): single-line base64 of the .p8. Leave blank if using the path above.
#   Generate with: base64 -i AuthKey_XXXX.p8 | tr -d '\n'
# APP_STORE_CONNECT_KEY_P8=

# 10-char team ID (developer.apple.com top-right)
APPLE_TEAM_ID=

# Private git repo that match uses to store encrypted certs/profiles.
# Create an empty private repo (e.g. siddarthkay/syncup-ios-certs) and put its SSH URL here.
MATCH_GIT_URL=git@github.com:siddarthkay/syncup-ios-certs.git

# Passphrase match uses to encrypt cert material in the repo above. Pick a strong one;
# you'll also add this as a GitHub Actions secret (MATCH_PASSWORD) so CI can decrypt.
MATCH_PASSWORD=
