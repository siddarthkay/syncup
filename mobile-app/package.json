{
  "name": "syncup",
  "version": "1.0.0",
  "main": "index.ts",
  "packageManager": "yarn@4.10.3",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "test": "jest"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.ts"
    ]
  },
  "dependencies": {
    "@babel/core": "^7.28.4",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@shopify/flash-list": "^2.3.1",
    "expo": "~54.0.10",
    "expo-camera": "~17.0.10",
    "expo-dev-client": "~6.0.12",
    "expo-file-system": "~19.0.21",
    "expo-haptics": "~15.0.8",
    "expo-media-library": "~18.2.1",
    "expo-sharing": "~14.0.8",
    "expo-status-bar": "~3.0.8",
    "expo-video": "~3.0.16",
    "react": "19.1.1",
    "react-native": "0.82.0",
    "react-native-blob-util": "^0.24.7",
    "react-native-pdf": "^7.0.4",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-safe-area-context": "^5.7.0",
    "react-native-svg": "^15.15.4",
    "react-native-webview": "13.15.0"
  },
  "devDependencies": {
    "@types/babel__core": "^7",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.1.0",
    "eslint": "^9.17.0",
    "eslint-config-expo": "^55.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "jest": "^30.3.0",
    "prettier": "^3.8.3",
    "ts-jest": "^29.4.9",
    "typescript": "~5.9.2"
  },
  "codegenConfig": {
    "name": "GoServerBridgeSpec",
    "type": "modules",
    "jsSrcsDir": "src",
    "android": {
      "javaPackageName": "com.siddarthkay.syncup"
    }
  },
  "expo": {
    "autolinking": {
      "exclude": {
        "android": [
          "expo-camera"
        ]
      },
      "buildFromSource": [
        ".*"
      ]
    }
  },
  "private": true,
  "resolutions": {
    "expo-modules-core@npm:3.0.18": "patch:expo-modules-core@npm%3A3.0.18#./patches/expo-modules-core-npm-3.0.18-8381554df1.patch",
    "expo-dev-launcher@npm:6.0.14": "patch:expo-dev-launcher@npm%3A6.0.14#./patches/expo-dev-launcher-npm-6.0.14-4b3774e49b.patch"
  }
}
